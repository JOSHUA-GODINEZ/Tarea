<VBox prefHeight="725.0" prefWidth="753.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.tarea.controller.TopUsersController">
   <children>
      <HBox alignment="CENTER" prefHeight="65.0" prefWidth="754.0">
