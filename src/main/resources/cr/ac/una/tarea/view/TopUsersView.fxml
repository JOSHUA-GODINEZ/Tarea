<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="725.0" prefWidth="859.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.tarea.controller.TopUsersController">
   <children>
      <HBox alignment="CENTER" maxHeight="60.0" minHeight="40.0" prefHeight="65.0" prefWidth="754.0" VBox.vgrow="ALWAYS">
         <children>
            <Label fx:id="LblTUser" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Top usuarios" HBox.hgrow="ALWAYS" />
            <Label fx:id="LblParametres" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Parametros de busqueda" HBox.hgrow="ALWAYS" />
         </children>
         <styleClass>
            <String fx:value="mi-rectangulo" />
            <String fx:value="mi-Titulos" />
         </styleClass>
      </HBox>
      <HBox prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="659.0" prefWidth="337.0" HBox.hgrow="ALWAYS">
               <children>
                  <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="564.0" prefWidth="369.0" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="rootTop" prefHeight="200.0" prefWidth="100.0">
                           <styleClass>
                              <String fx:value="mi-rectangulo" />
                              <String fx:value="mi-Titulos" />
                           </styleClass>
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
            <VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="659.0" prefWidth="354.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button maxHeight="60.0" maxWidth="200.0" minHeight="35.0" minWidth="40.0" mnemonicParsing="false" onAction="#onActionSinParametros" prefHeight="40.0" prefWidth="50.0" styleClass="mi-botonWithoutParameters" VBox.vgrow="ALWAYS" />
                  <HBox alignment="CENTER" maxHeight="100.0" prefHeight="37.0" prefWidth="385.0" spacing="10.0" VBox.vgrow="ALWAYS">
                     <children>
                        <DatePicker fx:id="FDesde" promptText="Desde" />
                        <DatePicker fx:id="FHasta" promptText="Hasta" />
                        <Button maxHeight="60.0" maxWidth="200.0" minHeight="40.0" minWidth="100.0" mnemonicParsing="false" onAction="#onActionBuscar" prefHeight="30.0" prefWidth="50.0" styleClass="mi-botonSearch" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <VBox maxHeight="1.7976931348623157E308" minHeight="100.0">
                     <children>
                        <HBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="44.0" prefWidth="383.0" spacing="20.0">
                           <children>
                              <Label text="Sucursal:" />
                              <Label fx:id="LSucursal" text="Sin Sucursal" />
                              <Label text="Estacion:" />
                              <Label fx:id="LEstacion" text="Sin Estacion" />
                           </children>
                           <styleClass>
                              <String fx:value="mi-Titulos" />
                              <String fx:value="mi-rectangulo" />
                           </styleClass>
                        </HBox>
                        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="mi-rectangulo" VBox.vgrow="ALWAYS">
                           <content>
                              <HBox fx:id="rootEsciones" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="100.0" prefWidth="200.0">
                                 <styleClass>
                                    <String fx:value="mi-rectangulo" />
                                    <String fx:value="mi-Titulos" />
                                 </styleClass></HBox>
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>
                  <VBox fx:id="rootGrafics" prefHeight="346.0" prefWidth="385.0">
                     <children>
                        <BarChart fx:id="GraficLines" styleClass="mi-panel-fondo1">
                          <xAxis>
                            <CategoryAxis side="BOTTOM" />
                          </xAxis>
                          <yAxis>
                            <NumberAxis side="LEFT" />
                          </yAxis>
                        </BarChart>
                        <PieChart fx:id="GraficPie" styleClass="mi-panel-fondo1" />
                     </children></VBox>
               </children>
               <styleClass>
                  <String fx:value="mi-rectangulo" />
                  <String fx:value="mi-boton" />
               </styleClass>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
