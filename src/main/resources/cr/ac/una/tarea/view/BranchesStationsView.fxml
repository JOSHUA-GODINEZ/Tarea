<VBox prefHeight="575.0" prefWidth="807.0" stylesheets="@Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cr.ac.una.tarea.controller.BranchesStationsController">
   <children>
      <HBox minHeight="50.0" prefHeight="128.0" prefWidth="807.0" VBox.vgrow="ALWAYS">
         <children>
            <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onActionAddBranch" styleClass="mi-botonAdd" HBox.hgrow="ALWAYS" />
            <Button maxHeight="100.0" maxWidth="300.0" mnemonicParsing="false" onAction="#onActionDelete" styleClass="mi-botonDelete" HBox.hgrow="ALWAYS" />
            <Button layoutX="438.0" layoutY="10.0" maxHeight="100.0" maxWidth="300.0" mnemonicParsing="false" onAction="#onActionEdit" styleClass="mi-botonEdit" HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" maxHeight="100.0" maxWidth="300.0" prefHeight="45.0" prefWidth="95.0" promptText="&lt;Buscar&gt;" HBox.hgrow="ALWAYS">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
            <Button maxHeight="100.0" maxWidth="300.0" mnemonicParsing="false" onAction="#onActionSave" styleClass="mi-botonSave" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
      <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="30.0" prefHeight="101.0" prefWidth="807.0" VBox.vgrow="ALWAYS">
         <children>
            <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Sucursales y Estaciones:" HBox.hgrow="ALWAYS" />
            <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Tramites Disponibles:" HBox.hgrow="ALWAYS" />
            <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Tramites de la estacion" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
      <HBox prefHeight="538.0" prefWidth="807.0" VBox.vgrow="ALWAYS">
         <children>
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="ALWAYS" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="474.0" prefWidth="416.0" vbarPolicy="ALWAYS" HBox.hgrow="ALWAYS">
               <content>
                  <VBox fx:id="rootBranches" alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="282.0" prefWidth="274.0" spacing="10.0">
                     <children>
                        <Accordion />
                     </children></VBox>
               </content>
            </ScrollPane>
            <VBox prefHeight="484.0" prefWidth="402.0">
