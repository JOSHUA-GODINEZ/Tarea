                  <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onActionRefresh" text="Actualizar" />
                  <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="449.0" prefWidth="310.0" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="rootProcedures" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" prefHeight="458.0" prefWidth="218.0" spacing="20.0">
                           <padding>
                              <Insets top="10.0" />
                           </padding>
