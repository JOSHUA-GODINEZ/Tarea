            </ImageView>
            <Region prefHeight="70.0" prefWidth="538.0" HBox.hgrow="ALWAYS" />
            <Accordion maxHeight="1.7976931348623157E308" maxWidth="150.0" prefHeight="92.0" prefWidth="185.0" HBox.hgrow="ALWAYS">
               <panes>
                <TitledPane alignment="TOP_CENTER" animated="false" maxHeight="1.7976931348623157E308" maxWidth="60.0" minHeight="10.0" prefHeight="92.0" prefWidth="240.0" text="Opciones">
                     <content>
                        <Button alignment="TOP_CENTER" mnemonicParsing="false" onAction="#onActionOption" prefHeight="24.0" prefWidth="131.0" text="Parametros Generales" />
                     </content>
                  </TitledPane>
               </panes>
            </Accordion>
         </children>
         <BorderPane.margin>
