                  <Tab fx:id="tab4" text="Frecuencia de Usuarios">
                    <content>
                      <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                    </content>
                  </Tab>
              </tabs>
            </TabPane>
         </children>
      </VBox>
   </center>
   <top>
      <HBox alignment="CENTER_RIGHT" maxHeight="400.0" maxWidth="1.7976931348623157E308" minHeight="20.0" prefHeight="70.0" prefWidth="770.0" BorderPane.alignment="CENTER">
